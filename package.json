{
  "name": "dcf",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev -w @dcf/server",
    "dev:client": "npm run dev -w @dcf/client",
    "build": "npm run build -w @dcf/client",
    "start": "npm run start -w @dcf/server",
    "heroku-postbuild": "npm run build -w @dcf/client",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit"
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3"
  }
}
